{
  "name": "scodash-server",
  "version": "0.1.0",
  "description": "Scodash API Server — talent scoring engine",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "seed:companies": "tsx scripts/seed-companies.ts",
    "seed:institutions": "tsx scripts/seed-institutions.ts",
    "seed:skills": "tsx scripts/seed-skills.ts",
    "seed:salaries": "tsx scripts/seed-salary-benchmarks.ts",
    "seed:embeddings": "tsx scripts/generate-embeddings.ts",
    "seed:all": "npm run db:seed && npm run seed:companies && npm run seed:institutions && npm run seed:skills && npm run seed:salaries && npm run seed:embeddings",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.2",
    "@upstash/redis": "^1.37.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "mammoth": "^1.12.0",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
